# Next.js API routes chạy ngay trong Vercel frontend.
# Đừng set NEXT_PUBLIC_API_BASE_URL nếu không còn dùng backend NestJS riêng.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: public market-data endpoint. Mặc định code dùng data-api.binance.vision.
BINANCE_BASE_URL=https://data-api.binance.vision
